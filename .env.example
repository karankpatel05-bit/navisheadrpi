# Get your free API key at https://console.groq.com/keys
GROQ_API_KEY=your_api_key_here

# Optional: Supabase PostgreSQL (omit to use local JSON file)
DATABASE_URL=

# ── Servo Configuration ────────────────────────────────────────
# BCM GPIO pin connected to servo signal wire (default: GPIO18 = hardware PWM)
SERVO_PIN=18

# Servo duty cycles (%)  — tune these for YOUR servo's range
# Standard SG90 / MG996R: ~5% = 0°, ~7.5% = 90°, ~10% = 180°
SERVO_OPEN_DC=7.5
SERVO_CLOSED_DC=5.0

# Flask port (must match navisrpi:5000 / mDNS)
PORT=5000
